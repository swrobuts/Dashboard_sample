# ── Database ─────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag_apple
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+psycopg://rag:rag@db:5432/rag_apple

# Neo4j (used by UE3 — GraphRAG)
# Inside the compose stack the service is called uc5-neo4j to avoid clashing
# with any pre-existing system Neo4j on the same Docker network.
NEO4J_URL=bolt://uc5-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── LLM providers ────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
# gemini-embedding-001 returns 3072 dims; we Matryoshka-truncate to 768 and
# re-normalise so the vector(768) HNSW index stays consistent.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

LOCAL_LLM_URL=http://host.docker.internal:1234/v1
LOCAL_LLM_MODEL=google/gemma-3-12b

# ── Source ───────────────────────────────────────────────
WIKIPEDIA_URL=https://de.wikipedia.org/wiki/Apple
WIKIPEDIA_USER_AGENT=UC5-RAG-Apple/0.1 (kontakt@example.com)

# ── Limits / cost guards ─────────────────────────────────
MAX_LLM_CALLS_PER_QUERY=8
MAX_TOKENS_PER_CALL=4096

# ── Chunking (UE1) ───────────────────────────────────────
UE1_CHUNK_TOKENS=400
UE1_CHUNK_OVERLAP=50
UE1_TOP_K=8

# ── PageIndex navigation (UE2) ───────────────────────────
UE2_MAX_DEPTH=3
UE2_NODES_PER_LEVEL=4
UE2_TOP_K=8

# ── Retrieval pipeline (UE1 & UE2 share this) ────────────
PIPELINE_INITIAL_K=30
PIPELINE_RRF_K=60
PIPELINE_RERANK_ENABLED=true
PIPELINE_RERANK_TOP_N=15
PIPELINE_MMR_ENABLED=true
PIPELINE_MMR_LAMBDA=0.7

# ── GraphRAG (UE3) ───────────────────────────────────────
UE3_TOP_K_ENTITIES=8
UE3_TOP_K_COMMUNITIES=3
UE3_TOP_K_CHUNKS=8
UE3_DEFAULT_MODE=hybrid
UE3_MAX_CHUNKS_PER_ENTITY=4
