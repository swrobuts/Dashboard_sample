# ── Database ─────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag_apple
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+psycopg://rag:rag@db:5432/rag_apple

# Neo4j (used only by UE3, can stay empty during UE1)
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── LLM providers ────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
# gemini-embedding-001 returns 3072 dims; we Matryoshka-truncate to 768 and
# re-normalise so the vector(768) HNSW index stays consistent.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

LOCAL_LLM_URL=http://host.docker.internal:1234/v1
LOCAL_LLM_MODEL=google/gemma-3-12b

# ── Source ───────────────────────────────────────────────
WIKIPEDIA_URL=https://de.wikipedia.org/wiki/Apple
WIKIPEDIA_USER_AGENT=UC5-RAG-Apple/0.1 (kontakt@example.com)

# ── Limits / cost guards ─────────────────────────────────
MAX_LLM_CALLS_PER_QUERY=8
MAX_TOKENS_PER_CALL=4096

# ── Chunking (UE1) ───────────────────────────────────────
UE1_CHUNK_TOKENS=400
UE1_CHUNK_OVERLAP=50
UE1_TOP_K=8
